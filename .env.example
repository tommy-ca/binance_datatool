# ── Prefect Task Runner ───────────────────────────────────────
# Thread pool workers for parallel symbol processing (download, verify, gap-fill)
# Default: 8
PREFECT_MAX_WORKERS=16

# ── Default Paths ─────────────────────────────────────────────
# Local archive root (mirrors data.binance.vision structure)
# Default: ~/.binance-datatool/archive
ARCHIVE_HOME=/data/crypto/binance-archive

# DuckLake catalog root (default: archive_home.parent / "lake")
CATALOG_PATH=/data/crypto/lake

# ── Pipeline Defaults ─────────────────────────────────────────
# Default lookback window in days
# Default: 30
DEFAULT_LOOKBACK_DAYS=90

# Default klines interval
# Default: 1h
DEFAULT_INTERVAL=1h

# ── REST API ──────────────────────────────────────────────────
# Binance REST API timeout in seconds
# Default: 30
REST_TIMEOUT_SECONDS=60

# Binance REST API retries on failure
# Default: 3
REST_RETRIES=5

# ── S3 Archive ────────────────────────────────────────────────
# S3-compatible endpoint for data.binance.vision
S3_ENDPOINT=https://s3-ap-northeast-1.amazonaws.com
S3_BUCKET=data.binance.vision
